---
import BaseLayout from '../layouts/BaseLayout.astro';
import Localized from '../components/Localized.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
---

<BaseLayout
  title="Angel Zurita — Full-stack Developer"
  description="Portafolio personal de Angel Zurita: desarrollo full-stack, cloud, inteligencia artificial y software para problemas reales."
>
  <header class="site-header">
    <a
      class="brand"
      href="#inicio"
      aria-label="Angel Zurita, volver al inicio"
      data-aria-es="Angel Zurita, volver al inicio"
      data-aria-en="Angel Zurita, back to top"
    >
      <svg viewBox="0 0 42 42" aria-hidden="true">
        <path d="M4 36 17 6h8l13 30M10 28h22M29 7h9L24 35h14" />
      </svg>
      <span>Angel Zurita</span>
    </a>

    <nav
      aria-label="Navegación principal"
      data-aria-es="Navegación principal"
      data-aria-en="Main navigation"
    >
      <a href="#inicio"><Localized es="Perfil" en="Profile" /></a>
      <a href="#proyectos"><Localized es="Proyectos" en="Projects" /></a>
      <a href="#recorrido"><Localized es="Recorrido" en="Path" /></a>
      <a href="#stack">Stack</a>
    </nav>

    <div class="header-actions">
      <button
        class="language-toggle"
        type="button"
        data-language-toggle
        aria-label="Cambiar idioma a inglés"
      >
        <span data-switch-for="es">EN</span>
        <span data-switch-for="en">ES</span>
      </button>
      <a class="header-contact" href="#contacto">
        <Localized es="Contacto" en="Contact" /> <span aria-hidden="true">↗</span>
      </a>
    </div>
  </header>

  <main id="contenido">
    <section class="hero" id="inicio" aria-labelledby="hero-title">
      <div class="hero__copy">
        <p class="eyebrow"><span></span> Full-stack · Software engineer · AI / SDD</p>
        <h1 id="hero-title">Angel<br /><em>Zurita.</em></h1>
        <p class="hero__tagline"><Localized es="Desarrollo software de punta a punta." en="I build software end to end." /></p>
        <p class="hero__intro">
          <Localized
            es="Soy desarrollador full-stack e ingeniero de software independiente en Monclova, Coahuila. Me gusta entender el problema completo: desde los datos y la arquitectura hasta la interfaz y el despliegue."
            en="I’m an independent full-stack developer and software engineer based in Monclova, Coahuila. I like understanding the whole problem—from data and architecture to interface and deployment."
          />
        </p>
        <div class="hero__actions">
          <a class="button button--primary" href="#proyectos"><Localized es="Conoce mi trabajo" en="Explore my work" /></a>
          <a class="text-link" href="https://github.com/AngelZurita28" target="_blank" rel="noreferrer">
            GitHub <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>

      <div class="hero__system" aria-hidden="true">
        <div class="system-map__top">
          <span>FULL STACK / 01—04</span>
          <span>AZ / BUILD</span>
        </div>
        <div class="system-map__canvas">
          <i class="system-map__axis"></i>
          <div class="system-layer system-layer--data">
            <span>01</span>
            <strong><Localized es="DATOS" en="DATA" /></strong>
            <small>SCHEMA / SIGNAL</small>
          </div>
          <div class="system-layer system-layer--systems">
            <span>02</span>
            <strong><Localized es="SISTEMAS" en="SYSTEMS" /></strong>
            <small>API / LOGIC</small>
          </div>
          <div class="system-layer system-layer--interface">
            <span>03</span>
            <strong><Localized es="INTERFAZ" en="INTERFACE" /></strong>
            <small>WEB / MOBILE</small>
          </div>
          <div class="system-layer system-layer--ai">
            <span>04</span>
            <strong><Localized es="IA" en="AI" /></strong>
            <small>RAG / AGENTS</small>
          </div>
        </div>
        <div class="system-map__footer">
          <span>MONCLOVA · COAHUILA · MX</span>
          <span>END TO END</span>
        </div>
      </div>

      <p class="hero__note">
        <Localized
          es="Proyectos comerciales y personales · software, cloud e inteligencia artificial"
          en="Commercial and personal projects · software, cloud, and artificial intelligence"
        />
      </p>
    </section>

    <section
      class="thesis"
      aria-label="Áreas de interés"
      data-aria-es="Áreas de interés"
      data-aria-en="Areas of interest"
    >
      <p><Localized es="Software que llega a producción." en="Software that reaches production." /></p>
      <span aria-hidden="true"></span>
      <p><Localized es="Investigación que se vuelve producto." en="Research turned into product." /></p>
    </section>

    <section class="now section-shell" id="ahora" aria-labelledby="now-title">
      <header class="now__header" data-reveal>
        <p class="eyebrow"><span></span> <Localized es="Ahora" en="Now" /></p>
        <h2 id="now-title">
          <Localized
            es="Un sistema completo para una PyME mexicana."
            en="A complete information system for a Mexican SME."
          />
        </h2>
      </header>

      <div class="now__body" data-reveal>
        <p>
          <Localized
            es="Actualmente participo en todo el proceso: descubrimiento, modelado de datos, arquitectura, backend, frontend, despliegue y evolución del producto."
            en="I’m currently involved throughout the process: discovery, data modeling, architecture, backend, frontend, deployment, and product evolution."
          />
        </p>
        <ul>
          <li><span>01</span><Localized es="Sistemas comerciales conectados a operaciones reales." en="Commercial systems connected to real operations." /></li>
          <li><span>02</span><Localized es="Arquitecturas cloud y productos full-stack mantenibles." en="Maintainable cloud and full-stack architectures." /></li>
          <li><span>03</span><Localized es="RAG, agentes con herramientas y modelos desplegables." en="RAG, tool-calling agents, and deployable models." /></li>
        </ul>
      </div>
    </section>

    <section class="work section-shell" id="proyectos" aria-labelledby="work-title">
      <header class="section-heading" data-reveal>
        <div>
          <p class="eyebrow"><span></span> <Localized es="Selección inicial" en="Initial selection" /></p>
          <h2 id="work-title"><Localized es="Algunas cosas que he construido." en="A few things I’ve built." /></h2>
        </div>
        <p>
          <Localized
            es="Proyectos comerciales, académicos y personales que han marcado mi recorrido. El archivo seguirá creciendo."
            en="Commercial, academic, and personal projects that have shaped my path. The archive will keep growing."
          />
        </p>
      </header>

      <div class="projects-grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>

    <section class="journey section-shell" id="recorrido" aria-labelledby="journey-title">
      <header class="journey__header" data-reveal>
        <p class="eyebrow eyebrow--light"><span></span> <Localized es="Mi recorrido" en="My path" /></p>
        <h2 id="journey-title"><Localized es="No llegué por una sola ruta." en="I didn’t get here through a single route." /></h2>
        <p>
          <Localized
            es="He aprendido moviéndome entre negocio, datos, diseño e ingeniería, sin perder de vista a la persona que usará el sistema."
            en="I’ve learned by moving between business, data, design, and engineering without losing sight of the person using the system."
          />
        </p>
      </header>

      <ol class="journey__timeline">
        <li data-reveal>
          <span class="journey__date"><Localized es="PRESENTE" en="PRESENT" /></span>
          <div>
            <h3><Localized es="Sistema para PyME" en="SME information system" /></h3>
            <p><Localized es="Desarrollo integral, desde el problema y los datos hasta el despliegue." en="End-to-end development, from problem and data to deployment." /></p>
          </div>
        </li>
        <li data-reveal>
          <span class="journey__date">2025 · NASA</span>
          <div>
            <h3>Data Orbit NASA</h3>
            <p><Localized es="RAG y búsqueda semántica para hacer más accesibles artículos científicos." en="RAG and semantic search making scientific articles easier to explore." /></p>
          </div>
        </li>
        <li data-reveal>
          <span class="journey__date">INNOVATEC · 3×</span>
          <div>
            <h3><Localized es="Etapa regional" en="Regional stage" /></h3>
            <p><Localized es="Proyectos de impacto social, crecimiento personal y soluciones financieras." en="Projects spanning social impact, personal growth, and financial solutions." /></p>
          </div>
        </li>
        <li data-reveal>
          <span class="journey__date"><Localized es="INVESTIGACIÓN" en="RESEARCH" /></span>
          <div>
            <h3><Localized es="Software regional" en="Regional software" /></h3>
            <p><Localized es="Herramientas para proyectos, postulaciones, asignaciones y seguimiento institucional." en="Tools for projects, applications, placement, and institutional follow-up." /></p>
          </div>
        </li>
      </ol>
    </section>

    <section class="method section-shell" id="principios" aria-labelledby="method-title">
      <header class="method__header" data-reveal>
        <p class="eyebrow eyebrow--light"><span></span> <Localized es="Principios" en="Principles" /></p>
        <h2 id="method-title"><Localized es="El problema completo, no sólo una capa." en="The whole problem, not just one layer." /></h2>
      </header>

      <ol class="method__steps">
        <li data-reveal>
          <span>01 / <Localized es="ENTENDER" en="UNDERSTAND" /></span>
          <h3><Localized es="Antes de abstraer" en="Before abstracting" /></h3>
          <p><Localized es="Primero busco personas, reglas, excepciones y consecuencias. Después elijo arquitectura." en="I look for people, rules, exceptions, and consequences before choosing an architecture." /></p>
        </li>
        <li data-reveal>
          <span>02 / <Localized es="CONECTAR" en="CONNECT" /></span>
          <h3><Localized es="Cruzar capas" en="Work across layers" /></h3>
          <p><Localized es="Datos, APIs, interfaces, infraestructura e IA forman un solo sistema." en="Data, APIs, interfaces, infrastructure, and AI form one system." /></p>
        </li>
        <li data-reveal>
          <span>03 / <Localized es="CONTINUAR" en="CONTINUE" /></span>
          <h3><Localized es="Construir para mantener" en="Build to maintain" /></h3>
          <p><Localized es="Prefiero software claro, trazable y desplegable sobre demos que nadie puede mantener." en="I prefer clear, traceable, deployable software over demos nobody can maintain." /></p>
        </li>
      </ol>
    </section>

    <section class="stack section-shell" id="stack" aria-labelledby="stack-title">
      <header class="section-heading" data-reveal>
        <div>
          <p class="eyebrow"><span></span> Tech stack</p>
          <h2 id="stack-title"><Localized es="Herramientas elegidas por contexto." en="Tools chosen around context." /></h2>
        </div>
        <p><Localized es="No intento usar todo en cada proyecto. Elijo stack según dominio, equipo y restricciones." en="I don’t try to use everything in every project. I choose a stack around domain, team, and constraints." /></p>
      </header>

      <div class="stack__grid">
        <article data-reveal>
          <span>01</span><h3><Localized es="Web y móvil" en="Web and mobile" /></h3>
          <p>TypeScript · JavaScript · Vue · React · Next.js · Astro · Flutter</p>
        </article>
        <article data-reveal>
          <span>02</span><h3><Localized es="Backend y sistemas" en="Backend and systems" /></h3>
          <p>C# · ASP.NET Core · PHP · Python · Node.js · Django · REST</p>
        </article>
        <article data-reveal>
          <span>03</span><h3><Localized es="Datos" en="Data" /></h3>
          <p>PostgreSQL · MariaDB · MySQL · SQL Server · MongoDB · Firebase</p>
        </article>
        <article data-reveal>
          <span>04</span><h3><Localized es="Cloud y operación" en="Cloud and operations" /></h3>
          <p>Docker · Linux · AWS · Cloudflare · GitHub · Nginx</p>
        </article>
        <article class="stack__ai" data-reveal>
          <span>05</span><h3><Localized es="IA aplicada" en="Applied AI" /></h3>
          <p>RAG · Tool-calling agents · LLMs · Embeddings · Semantic search · Fine-tuning · Hugging Face · llama.cpp</p>
        </article>
      </div>
    </section>

    <section class="contact" id="contacto" aria-labelledby="contact-title">
      <p class="eyebrow eyebrow--light"><span></span> <Localized es="Si te interesa lo que estoy construyendo" en="If you’re interested in what I’m building" /></p>
      <h2 id="contact-title"><Localized es="Software, IA e ideas difíciles." en="Software, AI, and difficult ideas." /></h2>
      <p class="contact__intro"><Localized es="Trabajo como freelancer en proyectos comerciales y personales. También disfruto conversar sobre arquitectura, investigación aplicada y productos que todavía están tomando forma." en="I work independently on commercial and personal projects. I also enjoy conversations about architecture, applied research, and products still taking shape." /></p>
      <div class="contact__links">
        <a href="https://www.linkedin.com/in/angel-fabian-zurita-garcia-b12b9b342/" target="_blank" rel="noreferrer">LinkedIn <span aria-hidden="true">↗</span></a>
        <a href="https://github.com/AngelZurita28" target="_blank" rel="noreferrer">GitHub <span aria-hidden="true">↗</span></a>
      </div>
      <footer>
        <p>Angel Zurita · Monclova, Coahuila · <Localized es="México" en="Mexico" /></p>
        <p><Localized es="Diseñado y construido con Astro" en="Designed and built with Astro" /></p>
      </footer>
    </section>
  </main>
</BaseLayout>
