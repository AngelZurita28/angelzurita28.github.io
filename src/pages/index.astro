---
import BaseLayout from '../layouts/BaseLayout.astro';
import Localized from '../components/Localized.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';

const projectSlots = [...projects, null, null];
---

<BaseLayout
  title="Angel Zurita — Full-stack Developer"
  description="Portafolio de Angel Zurita: desarrollo full-stack, arquitectura cloud e inteligencia artificial aplicada."
>
  <header class="site-header">
    <a class="brand" href="#inicio" aria-label="Angel Zurita, volver al inicio" data-aria-es="Angel Zurita, volver al inicio" data-aria-en="Angel Zurita, back to top">
      <svg viewBox="0 0 42 42" aria-hidden="true"><path d="M4 36 17 6h8l13 30M10 28h22M29 7h9L24 35h14" /></svg>
      <span>Angel Zurita</span>
    </a>

    <nav aria-label="Navegación principal" data-aria-es="Navegación principal" data-aria-en="Main navigation">
      <a href="#inicio"><Localized es="Perfil" en="Profile" /></a>
      <a href="#proyectos"><Localized es="Proyectos" en="Projects" /></a>
      <a href="#principios"><Localized es="Proceso" en="Process" /></a>
      <a href="#tecnologias">Stack</a>
    </nav>

    <div class="header-actions">
      <button class="language-toggle" type="button" data-language-toggle aria-label="Cambiar idioma a inglés"><span data-switch-for="es">EN</span><span data-switch-for="en">ES</span></button>
      <a class="header-contact" href="#contacto"><Localized es="Contacto" en="Contact" /> <span aria-hidden="true">↗</span></a>
    </div>
  </header>

  <main id="contenido">
    <section class="hero" id="inicio" aria-labelledby="hero-title">
      <div class="hero__copy">
        <p class="eyebrow"><span></span> Full-stack · Cloud · AI</p>
        <h1 id="hero-title">Angel<br /><em>Zurita.</em></h1>
        <p class="hero__intro">
          <Localized
            es="Soy ingeniero informático y desarrollador full-stack. Diseño productos digitales completos: desde datos, arquitectura y servicios escalables hasta interfaces cuidadas, despliegue cloud e inteligencia artificial aplicada."
            en="I’m a computer engineer and full-stack developer. I design complete digital products—from data, architecture, and scalable services to polished interfaces, cloud deployment, and applied AI."
          />
        </p>
        <p class="hero__detail">
          <Localized
            es="Conecto investigación de IA con software útil: RAG, agentes con herramientas, modelos ajustados y sistemas listos para operar."
            en="I connect AI research with useful software: RAG, tool-calling agents, fine-tuned models, and systems ready to run."
          />
        </p>
        <div class="hero__actions">
          <a class="button button--primary" href="#proyectos"><Localized es="Ver proyectos" en="View projects" /></a>
          <a class="text-link" href="#contacto"><Localized es="Hablemos" en="Let’s talk" /> <span aria-hidden="true">↗</span></a>
        </div>
      </div>

      <aside class="hero__stack" id="tecnologias" aria-labelledby="stack-hero-title">
        <div class="hero__stack-header"><p id="stack-hero-title"><Localized es="Tecnologías" en="Technologies" /></p><span>01—05</span></div>
        <ul>
          <li><span>01</span><div><strong><Localized es="Lenguajes" en="Languages" /></strong><p>Python · C# · C++ · TypeScript · JavaScript</p></div></li>
          <li><span>02</span><div><strong>Frontend</strong><p>React · Angular · Next.js · Astro · Vue</p></div></li>
          <li><span>03</span><div><strong>Backend</strong><p>Node.js · Django · ASP.NET · PHP</p></div></li>
          <li><span>04</span><div><strong><Localized es="Datos y cloud" en="Data and cloud" /></strong><p>PostgreSQL · MongoDB · AWS · Docker · Cloudflare</p></div></li>
          <li><span>05</span><div><strong><Localized es="IA aplicada" en="Applied AI" /></strong><p>Hugging Face · llama.cpp · LLMs · RAG</p></div></li>
        </ul>
        <p class="hero__stack-foot"><Localized es="Elegidas según contexto, no por costumbre." en="Chosen for context, never by habit." /></p>
      </aside>

      <p class="hero__note"><Localized es="Arquitectura cloud · Datos · Interfaces · IA aplicada" en="Cloud architecture · Data · Interfaces · Applied AI" /></p>
    </section>

    <section class="thesis" aria-label="Enfoque" data-aria-es="Enfoque" data-aria-en="Approach">
      <p><Localized es="Software listo para producción." en="Software ready for production." /></p><span aria-hidden="true"></span><p><Localized es="Investigación que se vuelve producto." en="Research turned into product." /></p>
    </section>

    <section class="method section-shell" id="principios" aria-labelledby="method-title">
      <header class="method__header" data-reveal>
        <p class="eyebrow eyebrow--light"><span></span> <Localized es="Cómo trabajo" en="How I work" /></p>
        <h2 id="method-title"><Localized es="Del problema a software que se sostiene." en="From the problem to software that lasts." /></h2>
        <p><Localized es="Un proceso claro para decisiones técnicas que también respondan al contexto real." en="A clear process for technical decisions that answer to real context." /></p>
      </header>

      <ol class="method__steps">
        <li data-reveal><span>01 / <Localized es="ENTENDER" en="UNDERSTAND" /></span><h3><Localized es="Escuchar antes de resolver" en="Listen before solving" /></h3><p><Localized es="Investigo necesidad, reglas, personas y límites; después trazo una ruta de solución." en="I study the need, rules, people, and constraints before mapping a path forward." /></p></li>
        <li data-reveal><span>02 / <Localized es="ADAPTAR" en="ADAPT" /></span><h3><Localized es="Diseñar para el entorno" en="Design for the environment" /></h3><p><Localized es="Contrasto alternativas con operación, equipo y objetivo para encontrar una solución viable, no sólo ideal." en="I weigh options against operations, team, and goals to find a viable solution, not merely an ideal one." /></p></li>
        <li data-reveal><span>03 / <Localized es="ESTRUCTURAR" en="STRUCTURE" /></span><h3><Localized es="Dar forma al sistema" en="Shape the system" /></h3><p><Localized es="Defino arquitectura, datos, tecnologías e interfaces que permitan trabajar con claridad y evolucionar sin fricción." en="I define architecture, data, technologies, and interfaces that make work clear and evolution frictionless." /></p></li>
        <li data-reveal><span>04 / <Localized es="ENTREGAR" en="DELIVER" /></span><h3><Localized es="Hacerlo operable" en="Make it operable" /></h3><p><Localized es="Integro APIs, interfaces y despliegue para entregar software claro, mantenible, trazable y fácil de poner en marcha." en="I connect APIs, interfaces, and deployment to deliver software that is clear, maintainable, traceable, and easy to run." /></p></li>
      </ol>
    </section>

    <section class="work section-shell" id="proyectos" aria-labelledby="work-title">
      <header class="section-heading" data-reveal>
        <div><p class="eyebrow"><span></span> <Localized es="Selección de trabajo" en="Selected work" /></p><h2 id="work-title"><Localized es="Proyectos que he construido." en="Projects I’ve built." /></h2></div>
        <p><Localized es="Productos comerciales, académicos y personales. Dos casos más llegarán pronto." en="Commercial, academic, and personal products. Two more cases are on their way." /></p>
      </header>
      <div class="projects-grid">
        {projectSlots.map((project, index) => project ? <ProjectCard project={project} /> : (
          <article class="project-card project-card--placeholder" data-reveal aria-label="Próximo proyecto" data-aria-es="Próximo proyecto" data-aria-en="Next project">
            <span>{String(index + 1).padStart(2, '0')}</span><div aria-hidden="true"></div><p><Localized es="Próximo caso" en="Next case" /></p>
          </article>
        ))}
      </div>
    </section>

    <section class="contact" id="contacto" aria-labelledby="contact-title">
      <p class="eyebrow eyebrow--light"><span></span> <Localized es="Contacto" en="Contact" /></p>
      <h2 id="contact-title"><Localized es="Hablemos y construyamos algo que importe." en="Let’s build something that matters." /></h2>
      <div class="contact__channels">
        <a href="https://www.linkedin.com/in/angel-fabian-zurita-garcia-b12b9b342/" target="_blank" rel="noreferrer"><span><Localized es="Encuéntrame en LinkedIn como" en="Find me on LinkedIn as" /></span><strong>Angel Fabián Zurita García</strong><i aria-hidden="true">↗</i></a>
        <a href="https://github.com/AngelZurita28" target="_blank" rel="noreferrer"><span><Localized es="Explora mi trabajo en" en="Explore my work on" /></span><strong>github.com/AngelZurita28</strong><i aria-hidden="true">↗</i></a>
        <a href="mailto:angel.zurita286@gmail.com"><span><Localized es="Escríbeme a" en="Write to me at" /></span><strong>angel.zurita286@gmail.com</strong><i aria-hidden="true">↗</i></a>
      </div>
      <footer><p>Angel Zurita</p><p><Localized es="Diseñado y construido con Astro" en="Designed and built with Astro" /></p></footer>
    </section>
  </main>
</BaseLayout>
